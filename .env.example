# Shiftee 로그인 정보
SHIFTEE_ID=your-email@example.com
SHIFTEE_PASSWORD=your-password

# 브라우저 설정
SHIFTEE_HEADLESS=true

# 타임아웃 설정 (밀리초)
# 자동화 사용 시 더 큰 값 권장
SHIFTEE_TIMEOUT=60000
SHIFTEE_NAVIGATION_TIMEOUT=60000

# 디버그 설정 (macOS 자동화 문제 진단용)
SHIFTEE_DEBUG_LOGS=false          # true로 설정하면 상세 로그 기록
SHIFTEE_DEBUG_SCREENSHOTS=false   # true로 설정하면 각 단계별 스크린샷 저장
SHIFTEE_LOG_FILE=logs/shiftee_debug.log  # 로그 파일 경로
