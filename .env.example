# Shiftee 로그인 정보
SHIFTEE_ID=
SHIFTEE_PASSWORD=

# 브라우저 설정
SHIFTEE_HEADLESS=true

# 타임아웃 설정 (밀리초)
# 자동화 사용 시 더 큰 값 권장
SHIFTEE_TIMEOUT=60000
SHIFTEE_NAVIGATION_TIMEOUT=60000

# 디버그 설정 (macOS 자동화 문제 진단용)
SHIFTEE_DEBUG_LOGS=false          # true로 설정하면 상세 로그 기록
SHIFTEE_DEBUG_SCREENSHOTS=false   # true로 설정하면 각 단계별 스크린샷 저장
SHIFTEE_LOG_FILE=logs/shiftee_debug.log  # 로그 파일 경로

# 분석 필터
SHIFTEE_TEAM_FILTER=                     # 특정 팀만 분석 (비워두면 전체)
SHIFTEE_EXCLUDE_ROLE=교대제               # 제외할 직무 (비워두면 제외 없음)

# 카카오톡 알림
SHIFTEE_KAKAO_APP_KEY=                   # 카카오 REST API 키
SHIFTEE_KAKAO_ACCESS_TOKEN=              # 카카오 액세스 토큰 (kakao_get_token.py로 발급)
SHIFTEE_KAKAO_REFRESH_TOKEN=             # 카카오 리프레시 토큰

# Slack 알림
SHIFTEE_SLACK_WEBHOOK_URL=               # Slack Incoming Webhook URL
